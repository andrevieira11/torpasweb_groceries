# =====================================================================
# MrList environment. Copy to .env and fill in. NEVER commit .env.
# Generate secrets:  openssl rand -hex 32
# Legend: [SECRET] never commit/share  [PUBLIC] shipped to browser  [CONFIG] non-sensitive
# =====================================================================

# ---- Postgres (the db service) ----
POSTGRES_USER=mrlist                               # [CONFIG]
POSTGRES_PASSWORD=change-me-hex-random             # [SECRET] openssl rand -hex 24
POSTGRES_DB=mrlist                                 # [CONFIG]

# ---- App DB connection. Host "db" = the compose service; password MUST match above. ----
DATABASE_URL=postgres://mrlist:change-me-hex-random@db:5432/mrlist?sslmode=disable   # [SECRET]

# ---- Better Auth ----
BETTER_AUTH_SECRET=change-me-32-byte-hex           # [SECRET] openssl rand -hex 32
BETTER_AUTH_URL=https://list.torpasweb.com         # [CONFIG] public canonical origin

# ---- Public app URL (inlined into the client bundle at BUILD time) ----
NEXT_PUBLIC_APP_URL=https://list.torpasweb.com     # [PUBLIC]

# ---- Siri / Shortcuts ingest webhook (voice + "add <recipe>") ----
INGEST_WEBHOOK_TOKEN=change-me-long-hex-token      # [SECRET] openssl rand -hex 32

# ---- Host port the app publishes (Caddy proxies to this) ----
APP_PORT=3000                                      # [CONFIG]
